{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/assets/(.*).mp4",
      "headers": [
        { "key": "Content-Type", "value": "video/mp4" },
        { "key": "Accept-Ranges", "value": "bytes" }
      ]
    },
    {
      "source": "/pdfs/(.*).pdf",
      "headers": [
        { "key": "Content-Type", "value": "application/pdf" }
      ]
    }
  ]
}
